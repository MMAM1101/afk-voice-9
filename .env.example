# Discord Bot Token — من Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Server ID — كليك يمين على السيرفر > Copy Server ID
GUILD_ID=your_guild_id_here

# Voice Channel ID — كليك يمين على القناة > Copy Channel ID
VOICE_CHANNEL_ID=your_voice_channel_id_here

# بادئة الأوامر (افتراضي: !)
PREFIX=!

# رقم البوت (للتمييز في اللوق)
BOT_NUMBER=1
